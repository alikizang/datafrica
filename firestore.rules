rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can read/write their own user document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Admins can read all user documents
      allow read: if request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Admin emails collection - readable by authenticated users (needed for admin check on login)
    match /adminEmails/{docId} {
      allow read: if request.auth != null;
      // Only writable via Admin SDK (server-side)
      allow write: if false;
    }

    // Datasets - publicly readable for listing and previews
    match /datasets/{datasetId} {
      allow read: if true;
      // Only writable via Admin SDK (server-side)
      allow write: if false;

      // Full data subcollection - only readable by authenticated users (access controlled by API)
      match /fullData/{docId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // Purchases - users can read their own purchases
    match /purchases/{purchaseId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      // Only writable via Admin SDK (server-side)
      allow write: if false;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
